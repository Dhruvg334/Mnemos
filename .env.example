APP_ENV=development
APP_NAME=Mnemos API
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://mnemos:mnemos@localhost:5432/mnemos
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=mnemos
S3_SECRET_KEY=mnemos-secret
S3_BUCKET=mnemos-documents
S3_REGION=us-east-1
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000
MOCK_AGENT_ENABLED=true
