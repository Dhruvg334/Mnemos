APP_ENV=development
APP_NAME=Mnemos API
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://mnemos:mnemos@localhost:5432/mnemos
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=mnemos
S3_SECRET_KEY=mnemos-secret
S3_BUCKET=mnemos-documents
S3_REGION=us-east-1
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000
MOCK_AGENT_ENABLED=true
MAX_UPLOAD_SIZE_BYTES=52428800
UPLOAD_SESSION_EXPIRE_MINUTES=15
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,text/markdown,text/plain,text/csv,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
AGENT_GATEWAY_MODE=mock
AGENT_SERVICE_URL=http://agent-service:8100
AGENT_SERVICE_TIMEOUT_SECONDS=30
AGENT_SERVICE_API_KEY=
INGESTION_GATEWAY_MODE=mock
INGESTION_SERVICE_URL=http://agent-service:8100
INGESTION_SERVICE_TIMEOUT_SECONDS=60
INGESTION_SERVICE_API_KEY=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
AUDIT_PAGE_SIZE_MAX=100
UPSTREAM_RETRY_ATTEMPTS=3
UPSTREAM_RETRY_BASE_DELAY_SECONDS=0.25
IDEMPOTENCY_KEY_MAX_LENGTH=128
IDEMPOTENCY_TTL_HOURS=24
QUERY_MAX_RETRY_ATTEMPTS=2
INGESTION_MAX_RETRY_ATTEMPTS=2
SECURITY_HEADERS_ENABLED=true
